set.seed(123456)
nn = 5*24
nn = 52*4
wn = ts(rnorm(nn), start=1970, frequency = 4)
# Time Series(시계열) 데이터를 만들기 위한 가장 기본적인 함수
# frequency : 1년(한 주기) 당 데이터의 개수
# start : 데이터 시작 시점
# rnorm : 정규분포 난수
wn = ts(rnorm(nn), start=1970, frequency = 4)
plot(wn, main="", xlab="", ylab="백색잡음", col="steelblue")
abline(h=0, lty=2, col='gray')
